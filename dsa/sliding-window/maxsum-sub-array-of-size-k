function maxSumSubarraySizeK(arr, k) {
    if(arr.length < k) {
        return 0;
    }
    let currentSum = 0;
    for(let i =0; i < k;i++) {
        currentSum += arr[i];
    }
    let maxSum = currentSum;
    for(i = k; i < arr.length;i++) {
        currentSum += arr[i] - arr[i-k];
        maxSum = Math.max(maxSum, currentSum);
    }
    return maxSum;
}
